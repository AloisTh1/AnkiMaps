{
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#4dfad6",
    "activityBar.background": "#4dfad6",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#db64fb",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "panel.border": "#4dfad6",
    "sash.hoverBorder": "#4dfad6",
    "sideBar.border": "#4dfad6",
    "statusBar.background": "#1cf8ca",
    "statusBar.border": "#1cf8ca",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#07daae",
    "statusBarItem.remoteBackground": "#1cf8ca",
    "statusBarItem.remoteForeground": "#15202b",
    "tab.activeBorder": "#4dfad6",
    "titleBar.activeBackground": "#1cf8ca",
    "titleBar.activeForeground": "#15202b",
    "titleBar.border": "#1cf8ca",
    "titleBar.inactiveBackground": "#1cf8ca99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#1cf8ca",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "charliermarsh.ruff",
  "ruff.enable": true,
  "ruff.configuration": "${workspaceFolder}/pyproject.toml",
  "peacock.remoteColor": "#33da45",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.importFormat": "relative",
  "ruff.interpreter": ["${workspaceFolder}/.venv/bin/python"],
  "terminal.integrated.defaultProfile.linux": "bash",
  "python.envFile": "${workspaceFolder}/.env"
}
